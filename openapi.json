        ],
        "summary": "List fuels compatible with each transport mode",
        "operationId": "list_fuels_api_v1_reference_fuels_get",
        "responses": {
          "200": {
            "description": "Per-mode list of valid fuel_type values (compatibility matrix).",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": {
                    "items": {
                      "type": "string"
                    },
                    "type": "array"
                  },
                  "type": "object",
                  "title": "Response List Fuels Api V1 Reference Fuels Get"
                },
                "example": {
                  "truck": [
                    "biodiesel_b20",
                    "diesel",
                    "diesel_b7",
                    "hvo100",
                    "lng"
                  ],
                  "rail": [
                    "diesel",
                    "electric",
                    "hvo100"
                  ],
                  "ship": [
                    "hfo",
                    "lng",
                    "methanol_green",
                    "methanol_grey",
                    "mgo"
                  ],
                  "air": [
                    "jet_a1",
                    "saf_blend_30",
                    "saf_neat"
                  ]
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/reference/regions": {
      "get": {
        "tags": [
          "Reference data"
        ],
        "summary": "List supported region codes and their grid factors (kgCO2e/kWh)",
        "operationId": "list_regions_api_v1_reference_regions_get",
        "responses": {
          "200": {
            "description": "Region code → grid factor (kgCO2e/kWh, EEA/EPA/IEA 2025 data).",
            "content": {
              "application/json": {
