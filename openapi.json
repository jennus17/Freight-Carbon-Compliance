{
  "openapi": "3.1.0",
  "info": {
    "title": "ESG Carbon API",
    "description": "REST API for calculating logistics carbon footprint (CO2e) in alignment with EU CSRD / ESRS E1 disclosure requirements. Supports DEFRA 2023, 2024 and 2025 vintages; alternative fuels (HVO, SAF, LNG, methanol, electric); regional grid factors; Stripe-style idempotency; and bulk calculation.",
    "contact": {
      "name": "ESG Compliance API"
    },
    "license": {
      "name": "Proprietary"
    },
    "version": "0.3.0"
  },
  "paths": {
    "/api/v1/emissions/calculate": {
      "post": {
        "tags": [
          "Emissions"
        ],
        "summary": "Calculate the carbon footprint of a single shipment",
        "description": "Calculate CO2-equivalent emissions for a freight shipment.\n\nRefinements available:\n  * `sub_mode` — vehicle/vessel class (e.g. `articulated_average`).\n  * `fuel_type` — alternative fuel pathway (`hvo100`, `saf_neat`, `electric`, ...).\n  * `region` — ISO-3166 code; localises grid factor when `fuel_type='electric'`.\n  * `methodology_version` — pin to a vintage (e.g. `'2023'`) for stable historical reports.\n\nThe full derivation appears in `methodology_reference.resolution_chain`.",
        "operationId": "calculate_emissions_api_v1_emissions_calculate_post",
        "parameters": [
          {
            "name": "Idempotency-Key",
            "in": "header",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Optional Stripe-style idempotency key. Same key + same body → cached response (header `Idempotent-Replayed: true`). Same key + different body → 409 Conflict. TTL 24h.",
              "examples": [
                "shipment-2026-08821-attempt-1"
              ],
              "title": "Idempotency-Key"
            },
            "description": "Optional Stripe-style idempotency key. Same key + same body → cached response (header `Idempotent-Replayed: true`). Same key + different body → 409 Conflict. TTL 24h."
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/EmissionRequest"
              },
              "examples": {
                "simple_truck": {
                  "summary": "Simple 1-tonne truck shipment, 100 km",
                  "description": "Minimal request — only the three required fields. Mode default (HGV all-average), fuel default (diesel), latest methodology.",
                  "value": {
                    "weight_kg": 1000,
                    "distance_km": 100,
                    "transport_type": "truck"
                  }
                },
                "electric_rail_france_2025": {
                  "summary": "25-tonne electric rail in France, DEFRA 2025",
                  "description": "Showcases regional grid factor: FR grid is ~12× cleaner than Poland, dragging the electric rail factor down accordingly.",
                  "value": {
                    "weight_kg": 25000,
                    "distance_km": 600,
                    "transport_type": "rail",
                    "fuel_type": "electric",
                    "region": "FR",
                    "methodology_version": "2025"
                  }
                },
                "air_freight_with_saf": {
                  "summary": "Long-haul air freight on 30% SAF blend",
                  "description": "Sustainable Aviation Fuel substitution via GLEC v3.0 §6.3 ratio method. ~25–30% emissions reduction vs neat Jet A-1.",
                  "value": {
                    "weight_kg": 500,
                    "distance_km": 9000,
                    "transport_type": "air",
                    "sub_mode": "long_haul",
                    "fuel_type": "saf_blend_30"
                  }
                },
                "container_ship_methanol": {
                  "summary": "Container ship on green methanol — alternative-fuel pathway",
                  "description": "e-methanol from renewable hydrogen (IMO MEPC.1/Circ.905). ~85–90% reduction vs heavy fuel oil baseline.",
                  "value": {
                    "weight_kg": 50000,
                    "distance_km": 8000,
                    "transport_type": "ship",
                    "sub_mode": "container",
                    "fuel_type": "methanol_green"
                  }
                },
                "pinned_historical_2023": {
                  "summary": "Pinned to DEFRA 2023 vintage (stable historical reports)",
                  "description": "When a customer's CSRD report cites a 2023-vintage figure, pin the calculation to '2023' so it never drifts as new vintages ship.",
                  "value": {
                    "weight_kg": 22000,
                    "distance_km": 850,
                    "transport_type": "truck",
                    "sub_mode": "articulated_average",
                    "methodology_version": "2023",
                    "shipment_id": "PO-2026-08821"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful calculation with full audit trail.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EmissionResponse"
                },
                "examples": {
                  "simple_truck": {
                    "summary": "Simple truck shipment",
                    "value": {
                      "transport_type": "truck",
                      "co2e_kg": 10.685,
                      "co2e_tonnes": 1.0685e-05,
                      "calculation": {
                        "mass_tonnes": 1.0,
                        "distance_km": 100.0,
                        "tonne_km": 100.0
                      },
                      "methodology_reference": {
                        "source": "UK DEFRA 2025 GHG Conversion Factors for Company Reporting",
                        "dataset": "Freighting goods",
                        "scope": "Well-to-Wheel (WTT + TTW combined)",
                        "unit": "kgCO2e per tonne-kilometre",
                        "version": "2025 v1.0",
                        "url": "https://www.gov.uk/government/publications/greenhouse-gas-reporting-conversion-factors-2025",
                        "csrd_alignment": "ESRS E1 – Climate change. Scope 3 Cat 4 / 9.",
                        "factor_kg_co2e_per_tkm": 0.10685,
                        "sub_mode_resolved": "default",
                        "fuel_resolved": "diesel",
                        "resolution_chain": [
                          {
                            "step": "base_factor",
                            "description": "DEFRA 2025 freight factor for truck/default",
                            "value_kg_co2e_per_tkm": 0.10685,
                            "source": "UK DEFRA 2025 GHG Conversion Factors for Company Reporting"
                          }
                        ],
                        "extra_references": {
                          "version_resolved": "2025",
                          "supported_versions": [
                            "2023",
                            "2024",
                            "2025"
                          ]
                        }
                      },
                      "calculated_at": "2026-04-26T12:36:21.000Z"
                    }
                  },
                  "electric_rail_france": {
                    "summary": "Electric rail in France with regional grid adjustment",
                    "value": {
                      "transport_type": "rail",
                      "co2e_kg": 93.706452,
                      "co2e_tonnes": 9.3706e-05,
                      "calculation": {
                        "mass_tonnes": 25.0,
                        "distance_km": 600.0,
                        "tonne_km": 15000.0
                      },
                      "methodology_reference": {
                        "source": "UK DEFRA 2025 GHG Conversion Factors for Company Reporting",
                        "dataset": "Freighting goods",
                        "scope": "Well-to-Wheel (WTT + TTW combined)",
                        "unit": "kgCO2e per tonne-kilometre",
                        "version": "2025 v1.0",
                        "url": "https://www.gov.uk/government/publications/greenhouse-gas-reporting-conversion-factors-2025",
                        "csrd_alignment": "ESRS E1 – Climate change. Scope 3 Cat 4 / 9.",
                        "factor_kg_co2e_per_tkm": 0.0062471,
                        "sub_mode_resolved": "electric",
                        "fuel_resolved": "electric",
                        "region_resolved": "FR",
                        "resolution_chain": [
                          {
                            "step": "base_factor",
                            "description": "DEFRA 2025 freight factor for rail/default",
                            "value_kg_co2e_per_tkm": 0.02675
                          },
                          {
                            "step": "switch_to_electric_base",
                            "description": "Replaced base factor with DEFRA rail/electric (0.02105).",
                            "value_kg_co2e_per_tkm": 0.02105
                          },
                          {
                            "step": "regional_grid_adjustment",
                            "description": "Adjusted from GB grid (0.15500) to FR grid (0.04600).",
                            "ratio": 0.29677,
                            "value_kg_co2e_per_tkm": 0.0062471
                          }
                        ],
                        "extra_references": {
                          "version_resolved": "2025",
                          "supported_versions": [
                            "2023",
                            "2024",
                            "2025"
                          ]
                        }
                      },
                      "calculated_at": "2026-04-26T12:36:21.000Z"
                    }
                  }
                }
              }
            }
          },
          "409": {
            "description": "Idempotency-Key reused with a different request body.",
            "content": {
              "application/json": {
                "example": {
                  "detail": "Idempotency-Key 'shipment-001' was previously used with a different request body."
                }
              }
            }
          },
          "422": {
            "description": "Request validation failed (bad input or incompatible fuel/region).",
            "content": {
              "application/json": {
                "examples": {
                  "incompatible_fuel": {
                    "summary": "Fuel/transport_type incompatibility",
                    "value": {
                      "detail": "fuel_type 'jet_a1' is not compatible with transport_type 'ship'. Compatible: ['hfo', 'lng', 'methanol_green', 'methanol_grey', 'mgo']."
                    }
                  },
                  "unknown_region": {
                    "summary": "Region not in supported list",
                    "value": {
                      "detail": "Unknown region 'ATLANTIS'. See /api/v1/reference/regions."
                    }
                  },
                  "field_validation": {
                    "summary": "Field-level validation (Pydantic)",
                    "value": {
                      "detail": [
                        {
                          "type": "greater_than",
                          "loc": [
                            "body",
                            "weight_kg"
                          ],
                          "msg": "Input should be greater than 0",
                          "input": 0
                        }
                      ]
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/emissions/batch": {
      "post": {
        "tags": [
          "Emissions"
        ],
        "summary": "Calculate emissions for up to 1000 shipments in one call",
        "description": "Bulk calculation endpoint. Each item is processed independently —\na single bad row does not fail the whole batch. The aggregate totals\ncover only successful items; failed items appear in `items[]` with\n`status='error'` and a structured error payload.",
        "operationId": "calculate_batch_api_v1_emissions_batch_post",
        "parameters": [
          {
            "name": "Idempotency-Key",
            "in": "header",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Optional Stripe-style idempotency key. Same key + same body → cached response (header `Idempotent-Replayed: true`). Same key + different body → 409 Conflict. TTL 24h.",
              "examples": [
                "batch-2026-q1-week14"
              ],
              "title": "Idempotency-Key"
            },
            "description": "Optional Stripe-style idempotency key. Same key + same body → cached response (header `Idempotent-Replayed: true`). Same key + different body → 409 Conflict. TTL 24h."
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BatchRequest"
              },
              "examples": {
                "three_modes": {
                  "summary": "Three shipments across truck / rail / ship",
                  "value": {
                    "items": [
                      {
                        "weight_kg": 1000,
                        "distance_km": 100,
                        "transport_type": "truck"
                      },
                      {
                        "weight_kg": 25000,
                        "distance_km": 600,
                        "transport_type": "rail",
                        "fuel_type": "electric",
                        "region": "FR"
                      },
                      {
                        "weight_kg": 50000,
                        "distance_km": 8000,
                        "transport_type": "ship",
                        "sub_mode": "container"
                      }
                    ]
                  }
                },
                "mixed_with_failure": {
                  "summary": "Failure isolation — one bad row, rest succeed",
                  "description": "Item 1 has an incompatible fuel (jet fuel on a ship). The other two complete normally; aggregate covers only successful items.",
                  "value": {
                    "items": [
                      {
                        "weight_kg": 1000,
                        "distance_km": 100,
                        "transport_type": "truck"
                      },
                      {
                        "weight_kg": 5000,
                        "distance_km": 500,
                        "transport_type": "ship",
                        "fuel_type": "jet_a1"
                      },
                      {
                        "weight_kg": 2000,
                        "distance_km": 300,
                        "transport_type": "rail"
                      }
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Batch result. Per-item failures do not fail the batch — see items[].status. Aggregate totals cover only successful items.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BatchResponse"
                },
                "examples": {
                  "all_success": {
                    "summary": "Three modes, all succeeded",
                    "value": {
                      "aggregate": {
                        "total_items": 3,
                        "successful": 3,
                        "failed": 0,
                        "total_co2e_kg": 884.69,
                        "total_co2e_tonnes": 0.00088469,
                        "by_transport_type_kg_co2e": {
                          "rail": 93.706452,
                          "ship": 780.296,
                          "truck": 10.685
                        }
                      },
                      "items": [
                        {
                          "index": 0,
                          "status": "ok",
                          "result": {
                            "transport_type": "truck",
                            "co2e_kg": 10.685,
                            "co2e_tonnes": 1.0685e-05,
                            "calculation": {
                              "mass_tonnes": 1.0,
                              "distance_km": 100.0,
                              "tonne_km": 100.0
                            },
                            "methodology_reference": {
                              "source": "UK DEFRA 2025 GHG Conversion Factors for Company Reporting",
                              "dataset": "Freighting goods",
                              "scope": "Well-to-Wheel (WTT + TTW combined)",
                              "unit": "kgCO2e per tonne-kilometre",
                              "version": "2025 v1.0",
                              "url": "https://www.gov.uk/government/publications/greenhouse-gas-reporting-conversion-factors-2025",
                              "csrd_alignment": "ESRS E1 – Climate change. Scope 3 Cat 4 / 9.",
                              "factor_kg_co2e_per_tkm": 0.10685,
                              "sub_mode_resolved": "default",
                              "fuel_resolved": "diesel",
                              "resolution_chain": [
                                {
                                  "step": "base_factor",
                                  "description": "DEFRA 2025 freight factor for truck/default",
                                  "value_kg_co2e_per_tkm": 0.10685,
                                  "source": "UK DEFRA 2025 GHG Conversion Factors for Company Reporting"
                                }
                              ],
                              "extra_references": {
                                "version_resolved": "2025",
                                "supported_versions": [
                                  "2023",
                                  "2024",
                                  "2025"
                                ]
                              }
                            },
                            "calculated_at": "2026-04-26T12:36:21.000Z"
                          }
                        },
                        {
                          "index": 1,
                          "status": "ok",
                          "result": {
                            "transport_type": "rail",
                            "co2e_kg": 93.706452,
                            "co2e_tonnes": 9.3706e-05,
                            "calculation": {
                              "mass_tonnes": 25.0,
                              "distance_km": 600.0,
                              "tonne_km": 15000.0
                            },
                            "methodology_reference": {
                              "source": "UK DEFRA 2025 GHG Conversion Factors for Company Reporting",
                              "dataset": "Freighting goods",
                              "scope": "Well-to-Wheel (WTT + TTW combined)",
                              "unit": "kgCO2e per tonne-kilometre",
                              "version": "2025 v1.0",
                              "url": "https://www.gov.uk/government/publications/greenhouse-gas-reporting-conversion-factors-2025",
                              "csrd_alignment": "ESRS E1 – Climate change. Scope 3 Cat 4 / 9.",
                              "factor_kg_co2e_per_tkm": 0.0062471,
                              "sub_mode_resolved": "electric",
                              "fuel_resolved": "electric",
                              "region_resolved": "FR",
                              "resolution_chain": [
                                {
                                  "step": "base_factor",
                                  "description": "DEFRA 2025 freight factor for rail/default",
                                  "value_kg_co2e_per_tkm": 0.02675
                                },
                                {
                                  "step": "switch_to_electric_base",
                                  "description": "Replaced base factor with DEFRA rail/electric (0.02105).",
                                  "value_kg_co2e_per_tkm": 0.02105
                                },
                                {
                                  "step": "regional_grid_adjustment",
                                  "description": "Adjusted from GB grid (0.15500) to FR grid (0.04600).",
                                  "ratio": 0.29677,
                                  "value_kg_co2e_per_tkm": 0.0062471
                                }
                              ],
                              "extra_references": {
                                "version_resolved": "2025",
                                "supported_versions": [
                                  "2023",
                                  "2024",
                                  "2025"
                                ]
                              }
                            },
                            "calculated_at": "2026-04-26T12:36:21.000Z"
                          }
                        },
                        {
                          "index": 2,
                          "status": "ok",
                          "result": "(...EmissionResponse for ship omitted for brevity)"
                        }
                      ],
                      "methodology_version_used": "2025"
                    }
                  },
                  "mixed_with_failure": {
                    "summary": "One row failed (incompatible fuel) — others succeeded",
                    "value": {
                      "aggregate": {
                        "total_items": 3,
                        "successful": 2,
                        "failed": 1,
                        "total_co2e_kg": 26.985,
                        "total_co2e_tonnes": 2.6985e-05,
                        "by_transport_type_kg_co2e": {
                          "rail": 16.3,
                          "truck": 10.685
                        }
                      },
                      "items": [
                        {
                          "index": 0,
                          "status": "ok",
                          "result": "(...EmissionResponse for truck...)"
                        },
                        {
                          "index": 1,
                          "status": "error",
                          "error": {
                            "type": "IncompatibleFuelError",
                            "detail": "fuel_type 'jet_a1' is not compatible with transport_type 'ship'. Compatible: ['hfo', 'lng', 'methanol_green', 'methanol_grey', 'mgo']."
                          }
                        },
                        {
                          "index": 2,
                          "status": "ok",
                          "result": "(...EmissionResponse for rail...)"
                        }
                      ],
                      "methodology_version_used": "2025"
                    }
                  }
                }
              }
            }
          },
          "409": {
            "description": "Idempotency-Key reused with a different batch body.",
            "content": {
              "application/json": {
                "example": {
                  "detail": "Idempotency-Key 'batch-001' was previously used with a different request body."
                }
              }
            }
          },
          "422": {
            "description": "Batch validation failed (empty items, oversize, malformed items).",
            "content": {
              "application/json": {
                "example": {
                  "detail": [
                    {
                      "type": "too_long",
                      "loc": [
                        "body",
                        "items"
                      ],
                      "msg": "List should have at most 1000 items after validation, not 1001"
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/emissions/modes": {
      "get": {
        "tags": [
          "Emissions"
        ],
        "summary": "List supported transport modes and sub-modes",
        "operationId": "list_modes_api_v1_emissions_modes_get",
        "responses": {
          "200": {
            "description": "Per-mode list of valid sub_mode values.",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": {
                    "items": {
                      "type": "string"
                    },
                    "type": "array"
                  },
                  "type": "object",
                  "title": "Response List Modes Api V1 Emissions Modes Get"
                },
                "example": {
                  "truck": [
                    "articulated_average",
                    "rigid_average",
                    "van_class_iii"
                  ],
                  "rail": [
                    "diesel",
                    "electric"
                  ],
                  "ship": [
                    "bulk_carrier",
                    "container",
                    "ro_ro_ferry",
                    "tanker_general_cargo"
                  ],
                  "air": [
                    "domestic",
                    "long_haul",
                    "short_haul"
                  ]
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
