# Copy to `.env` for local dev, or set these as env vars on your host.
# All settings are prefixed with ESG_ — see app/core/config.py.

# ── REQUIRED in production (RapidAPI deploy) ──────────────────────────────
# The shared secret RapidAPI injects on every proxied request via the
# `X-RapidAPI-Proxy-Secret` header. Find it in your RapidAPI dashboard:
#   My APIs → <your API> → Settings → "API Authentication"
# Leaving this empty disables the check (intended for local dev only).
ESG_RAPIDAPI_PROXY_SECRET=

# ── Observability ─────────────────────────────────────────────────────────
ESG_LOG_LEVEL=INFO
ESG_LOG_FORMAT=json          # "json" for prod, "console" for human-readable dev
ESG_METRICS_ENABLED=true
